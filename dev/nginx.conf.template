server {
    listen 80;
    root /usr/share/nginx/html;

    location / {
        # nginx secure_link: validates the ?md5=HASH&expires=TS query params
        # signed by authd using the shared RECORDINGS_SECRET. The MD5 input
        # must match what authd computes: "$expires$uri $secret".
        secure_link $arg_md5,$arg_expires;
        secure_link_md5 "$secure_link_expires$uri ${RECORDINGS_SECRET}";

        # Empty secure_link = invalid/missing token.
        if ($secure_link = "") {
            return 403;
        }
        # "0" = token present but expired.
        if ($secure_link = "0") {
            return 410;
        }

        # Serve the file; Accept-Ranges lets browsers seek within videos.
        add_header Accept-Ranges bytes always;
        try_files $uri =404;
    }
}
